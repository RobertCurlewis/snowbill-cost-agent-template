{
  "name": "cortex-agent-template",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".."
  },
  "features": {
    "ghcr.io/devcontainers/features/node:2": { "version": "24" }
  },
  "mounts": [
    "source=${localEnv:HOME}/.snowflake,target=/home/vscode/.snowflake,type=bind",
    "source=${localEnv:HOME}/.dbt,target=/home/vscode/.dbt,type=bind,readonly",
    "source=${localEnv:HOME}/KeyPairs,target=/home/vscode/KeyPairs,type=bind,readonly"
  ],
  "containerEnv": {
    "SNOWFLAKE_DEFAULT_CONNECTION_NAME": "dev",
    "DBT_TARGET": "dev",
    "DBT_KEY_PATH": "/home/vscode/KeyPairs/rsa_key.p8"
  },
  "remoteEnv": {
    "PATH": "${containerEnv:PATH}:/home/vscode/.local/bin"
  },
  "forwardPorts": [8080],
  "portsAttributes": {
    "8080": { "label": "dbt docs", "onAutoForward": "silent" }
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "charliermarsh.ruff",
        "sqlfluff.vscode-sqlfluff",
        "innoverio.vscode-dbt-power-user",
        "snowflake.snowflake-vsc",
        "samuelcolvin.jinjahtml",
        "redhat.vscode-yaml",
        "DavidAnson.vscode-markdownlint"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash",
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "sqlfluff.config": "${containerWorkspaceFolder}/.sqlfluff"
      }
    }
  },
  "onCreateCommand": "npm install -g markdownlint-cli2@0.22.1 && pip install snowflake-cli==3.17.1",
  "postCreateCommand": "bash .devcontainer/post-create.sh",
  "postStartCommand": "bash .devcontainer/post-start.sh",
  "remoteUser": "vscode"
}
